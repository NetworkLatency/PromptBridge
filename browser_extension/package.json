{
  "name": "promptbridge-browser-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "lucide": "1.24.0"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "shell-quote": "1.8.4",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
